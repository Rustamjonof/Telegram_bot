# @Startdaily_bot — environment variables
# Bu faylni nusxalab `.env` qiling va qiymatlarni to'ldiring.
# Serverda: `export $(cat .env | xargs)` yoki systemd/Docker orqali yuklang.

# Telegram bot tokeni (@BotFather dan)
BOT_TOKEN=

# Admin Telegram ID (raqam)
ADMIN_ID=5236920689

# Admin username (@ bilan)
ADMIN_USERNAME=@Rustamjonoff1

# Bot username (@ siz)
BOT_USERNAME=Startdaily_bot

# To'lov cheklari yuboriladigan kanal ID (-100... ko'rinishida)
PAYMENT_CHANNEL=-1003968636090

# OpenWeatherMap API kaliti (ob-havo uchun)
OPENWEATHER_API=

# ExchangeRate API kaliti (ixtiyoriy)
EXCHANGERATE_API=

# Groq API kaliti (bepul AI)
GROQ_API_KEY=

# OpenAI API kaliti (Standart/Premium AI va rasm uchun)
OPENAI_API=
